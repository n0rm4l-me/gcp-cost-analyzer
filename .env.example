# GCP Billing Account ID — format: XXXXXX-XXXXXX-XXXXXX
GCP_BILLING_ACCOUNT_ID=

# Path to GCP Service Account JSON key
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# GCP Project ID for resource analysis (optional)
GCP_PROJECT_ID=

# Gemini API key for AI recommendations (optional)
GEMINI_API_KEY=
